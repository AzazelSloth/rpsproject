        -288
      ],
      "id": "dff83ca2-7c16-444a-9c63-0d564024041c",
      "name": "Assemblage des réponses"
    },
    {
      "parameters": {
        "jsCode": "let text = $json.output;\n\n// 1. Enlever les doubles étoiles pour le gras\ntext = text.replace(/\\*\\*/g, '');\n\n// 2. Transformer les titres ### en lignes simples et nettes\ntext = text.replace(/###\\s?/g, '');\ntext = text.replace(/##\\s?/g, '');\n\n// 3. Optionnel : Ajouter un peu d'espace entre les sections\ntext = text.replace(/\\n/g, '\\r\\n');\n\nreturn {\n  clean_text: text\n};"
      },
