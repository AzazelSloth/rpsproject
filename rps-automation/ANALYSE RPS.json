      "parameters": {
        "jsCode": "// On récupère tous les employés (3 items en entrée)\nconst allItems = $input.all();\n\n// On construit une seule grande chaîne de texte avec toutes les infos\nlet texteGlobal = \"LISTE DES RÉSULTATS DE SONDAGE POUR L'ANALYSE GLOBALE :\\n\\n\";\n\nfor (const item of allItems) {\n  texteGlobal += `--- EMPLOYÉ ---\\n`;\n  texteGlobal += `Nom: ${item.json.employe_nom}\\n`;\n  texteGlobal += `Poste: ${item.json.titre_pro}\\n`;\n  texteGlobal += `Score Charge: ${item.json.score_charge_travail}/5\\n`;\n  texteGlobal += `Commentaire: ${item.json.commentaires_libres}\\n\\n`;\n}\n\n// On retourne un SEUL item (Output: 1 item) contenant tout le texte\nreturn {\n  donnees_synthese: texteGlobal\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
