    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst toutesLesLignes = items[0].json.data;\nlet textePourIA = \"RÉSULTATS DU SONDAGE :\\n\\n\";\ntoutesLesLignes.forEach((ligne, index) => {\n  textePourIA += `--- EMPLOYÉ #${index + 1} ---\\n`;\n  for (const [colonne, reponse] of Object.entries(ligne)) {\n    textePourIA += `${colonne} : ${reponse}\\n`;\n  }\n  textePourIA += \"\\n\";\n});\nreturn { donnees_assemblees: textePourIA };"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -528,
        -224
      ],
      "id": "dff83ca2-7c16-444a-9c63-0d564024041c",
      "name": "Assemblage des réponses"
    },
    {
      "parameters": {
        "jsCode": "const text = items[0].json.output;\nfunction extract(titleRegex, nextTitleRegex, source) {\n  const startMatch = source.match(titleRegex);\n  if (!startMatch) return \"Section non trouvée\";\n  const startIndex = startMatch.index + startMatch[0].length;\n  const rest = source.substring(startIndex);\n  const endMatch = rest.match(nextTitleRegex);\n  return endMatch ? rest.substring(0, endMatch.index).trim() : rest.trim();\n}\nreturn {\n  introduction: extract(/Introduction|Charge de travail/i, /Organisation & Éthique/i, text),\n  tendances: extract(/Organisation & Éthique/i, /Autonomie/i, text),\n  alertes: extract(/Autonomie/i, /Reconnaissance/i, text),\n  recommandations: extract(/Reconnaissance/i, /Conclusion/i, text),\n  conclusion: extract(/Conclusion/i, /$/i, text)\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
