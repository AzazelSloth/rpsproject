    {
      "parameters": {
        "jsCode": "// On récupère la liste créée par le nœud Aggregate\nconst items = $input.all();\nconst toutesLesLignes = items[0].json.data; \n\nlet textePourIA = \"RÉSULTATS DU SONDAGE :\\n\\n\";\n\ntoutesLesLignes.forEach((ligne, index) => {\n  textePourIA += `--- RÉPONSES EMPLOYÉ #${index + 1} ---\\n`;\n  for (const [colonne, reponse] of Object.entries(ligne)) {\n    // On ajoute chaque question et sa réponse au texte\n    textePourIA += `${colonne} : ${reponse}\\n`;\n  }\n  textePourIA += \"\\n\";\n});\n\nreturn {\n  donnees_assemblees: textePourIA\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -528,
        -224
      ],
      "id": "dff83ca2-7c16-444a-9c63-0d564024041c",
      "name": "Assemblage des réponses"
    },
    {
      "parameters": {
        "jsCode": "const text = items[0].json.output;\n\n// Fonction robuste pour extraire entre deux titres ou jusqu'à la fin\nfunction extract(titleRegex, nextTitleRegex, source) {\n  const startMatch = source.match(titleRegex);\n  if (!startMatch) return \"Section non trouvée\";\n  \n  const startIndex = startMatch.index + startMatch[0].length;\n  const rest = source.substring(startIndex);\n  \n  const endMatch = rest.match(nextTitleRegex);\n  const content = endMatch ? rest.substring(0, endMatch.index) : rest;\n  \n  return content.trim();\n}\n\n// On définit les Regex pour chaque section (insensible à la casse avec 'i')\nconst reIntro = /Introduction|Charge de travail/i;\nconst reTendances = /Tendances Générales|Organisation & Éthique/i;\nconst reAlertes = /Alertes Critiques|Autonomie et Développement/i;\nconst reRecom = /Recommandations Prioritaires|Reconnaissance/i;\nconst reConclusion = /Conclusion/i;\n\nreturn {\n  introduction: extract(reIntro, /Organisation & Éthique|Tendances/i, text),\n  tendances: extract(reTendances, /Autonomie|Alertes/i, text),\n  alertes: extract(reAlertes, /Reconnaissance|Recommandations/i, text),\n  recommandations: extract(reRecom, /Conclusion/i, text),\n  conclusion: extract(reConclusion, /$^/i, text), // $^ pour aller jusqu'à la fin\n  full_text_clean: text.trim()\n};"
      },
