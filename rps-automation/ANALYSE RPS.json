        "jsCode": "const employees = items[0].json.body.body || [];\nreturn employees.map(emp => {\n  let formattedData = {\n    \"Employeur\": emp.Employeur,\n    \"Email\": emp.Email,\n    \"Nom et Prenom\": emp[\"Nom et Prenom\"],\n    \"Fonction\": emp.Fonction,\n    \"Statut\": \"OK\"\n  };\n  for (let i = 1; i <= 28; i++) formattedData[`Q${i}`] = emp[`Q${i}`] || null;\n  return { json: formattedData };\n});"
