    {
      "parameters": {
        "jsCode": "// Construire le rapport final formaté\nconst analysis = $input.first().json.output || $input.first().json.text || $input.first().json.response || Object.values($input.first().json)[0];const campaignInfo = $('Formater les données').first().json.campaignInfo;\n\nconst now = new Date();\nconst dateStr = now.toLocaleDateString('fr-CA', { year: 'numeric', month: 'long', day: 'numeric' });\n\nconst rapport = `\n=================================================\nRAPPORT D'ANALYSE RPS\n=================================================\nEntreprise    : ${campaignInfo.entreprise}\nCampagne      : ${campaignInfo.campagne}\nDate d'analyse: ${dateStr}\nRépondants    : ${campaignInfo.total_repondants}\n=================================================\n\n${analysis}\n\n=================================================\nRapport généré automatiquement par la plateforme RPS\nConfidentiel - Usage interne uniquement\n=================================================\n`.trim();\n\nreturn [{\n  json: {\n    rapport,\n    campaignInfo,\n    subject: `Rapport RPS -  - ${campaignInfo.campagne}`,\n    filename: `Rapport_RPS.replace(/\\s+/g, '_')}_${now.toISOString().split('T')[0]}.txt`\n  }\n}];"
      },
      "id": "8de640ff-9760-4ce9-826e-a5ebc5ae8cbd",
      "name": "Construire le rapport",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        64,
        112
      ],
      "notes": "Formate le rapport final avec en-tête et pied de page."
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Analyse les résultats RPS  ",
        "options": {
          "systemMessage": "=Tu es un Expert Senior en Psychologie du Travail. Tu analyses les résultats du sondage RPS de \n\nMéthodologie d'analyse :\nLes employés ont répondu avec l'échelle suivante. Tu dois les interpréter ainsi :\n\n    \"Tout à fait d'accord\" ou \"Plutôt d'accord\" : Score 4-5 (Facteur de protection / Satisfaction).\n\n    \"Ni d'accord, ni pas d'accord\" : Score 3 (Zone neutre).\n\n    \"Plutôt pas d'accord\" ou \"Pas du tout d'accord\" : Score 1-2 (Alerte / Risque psychosocial).\n\nNote : Analyse l'ensemble des réponses pour dégager des moyennes et des tendances de groupe, peu importe le nombre de répondants.\n\nConsignes de formatage :\n\n    AUCUN formatage Markdown (pas de #, pas de *, pas de **).\n\n    Utilise uniquement les titres de sections ci-dessous.\n\n\nStructure du Rapport :\n\nCharge de travail\n(Analyse la quantité, le rythme et la complexité perçue).\n\nOrganisation & Étique\n(Analyse la clarté des rôles et le respect des valeurs).\n\nAutonomie et Développement\n(Analyse la liberté de décision et l'utilisation des compétences).\n\nReconnaissance & condition\n(Analyse le sentiment de justice et la valorisation du travail).\n\nRelation et Soutien\n(Analyse l'ambiance d'équipe et le soutien managérial).\n\nDemandes Émotionnelles & Valeurs\n(Analyse la charge mentale liée au public et les conflits d'éthique).\n\nConséquence sur la santé et Équilibre\n(Analyse l'impact sur le bien-être et la vie personnelle).\n\nAvis pour améliorer le bien être au travail\n(Propose 3 actions concrètes et adaptées à Solutions Tech Québec)."
        }
      },
