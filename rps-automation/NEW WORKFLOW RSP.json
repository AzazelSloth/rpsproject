                  {
                      "parameters":  {
                                         "jsCode":  "const payload = $input.first().json;\nconst campaigns = Array.isArray(payload.campaigns) ? payload.campaigns : [];\nconst participants = [];\n\nfor (const campaign of campaigns) {\n  const campaignParticipants = Array.isArray(campaign.participants) ? campaign.participants : [];\n\n  for (const participant of campaignParticipants) {\n    participants.push({\n      json: {\n        ...participant,\n        campaign_id: participant.campaign_id || campaign.campaign_id,\n        campaign_name: participant.campaign_name || campaign.campaign_name,\n        company_name: participant.company_name || campaign.company_name,\n      },\n    });\n  }\n}\n\nreturn participants;"
                                     },
                      "id":  "70787110-1a7e-47c0-8d32-e6cdfe793319",
                      "name":  "Filtrer non completes",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       704,
                                       864
                                   ],
                      "notes":  "Transforme la reponse /automation/campaigns/pending-reminders en participants individuels."
                  },
                  {
                      "parameters":  {
                                         "jsCode":  "const env = typeof $env === \u0027undefined\u0027 ? {} : $env;\nconst minDays = Number(env.REMINDER_MIN_DAYS || 6);\nconst maxCount = Number(env.REMINDER_MAX_COUNT || 2);\nconst now = Date.now();\nconst result = [];\n\nfor (const item of $input.all()) {\n  const participant = item.json;\n\n  if (!participant.email || participant.status === \u0027completed\u0027) {\n    continue;\n  }\n\n  const reminderCount = Number(participant.reminder_count || 0);\n  if (Number.isFinite(maxCount) \u0026\u0026 maxCount \u003e= 0 \u0026\u0026 reminderCount \u003e= maxCount) {\n    continue;\n  }\n\n  const invitationDate = participant.invitation_sent_at ? new Date(participant.invitation_sent_at) : null;\n  if (!invitationDate || Number.isNaN(invitationDate.getTime())) {\n    continue;\n  }\n\n  const daysSinceInvitation = Math.floor((now - invitationDate.getTime()) / (1000 * 60 * 60 * 24));\n  if (daysSinceInvitation \u003c minDays) {\n    continue;\n  }\n\n  result.push({\n    json: {\n      ...participant,\n      jours_depuis_envoi: daysSinceInvitation,\n      eligible_relance: true,\n    },\n  });\n}\n\nreturn result;"
                                     },
