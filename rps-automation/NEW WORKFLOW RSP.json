      "parameters": {
        "jsCode": "const items = $input.all();\nconst result = [];\n\nfor (const item of items) {\n  const employe = item.json;\n  const dateEnvoi = new Date(employe.date_envoi);\n  const aujourdhui = new Date();\n  const diffJours = Math.floor((aujourdhui - dateEnvoi) / (1000 * 60 * 60 * 24));\n\n  if (diffJours >= 6) {\n    result.push({\n      json: {\n        ...employe,\n        jours_depuis_envoi: diffJours,\n        eligible_relance: true\n      }\n    });\n  }\n}\n\nreturn result;"
      },
      "id": "679d5bc3-5ed1-4aeb-90df-1e3e5f593bcc",
