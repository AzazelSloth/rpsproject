                  {
                      "parameters":  {
                                         "jsCode":  "const participant = $(\u0027Calculer 6 jours\u0027).item.json;\nconst reminderResult = $input.first().json;\nconsole.log(`Relance envoyee a ${participant.nom} (${participant.email}) - ${participant.jours_depuis_envoi} jours depuis l\u0027invitation`);\n\nreturn [{\n  json: {\n    status: \u0027relance_envoyee\u0027,\n    participant_id: participant.participant_id,\n    nom: participant.nom,\n    email: participant.email,\n    jours_depuis_envoi: participant.jours_depuis_envoi,\n    reminder_marked: reminderResult.updated ?? true,\n    timestamp: new Date().toISOString()\n  }\n}];"
                                     },
