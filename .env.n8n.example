# ============================================
# Configuration n8n - Webhook Integration
# ============================================

# Domaine public de l'instance n8n (si n8n est self-hosted).
# Avec le sous-domaine automation.laroche360.ca, n8n doit rester a la racine
# (N8N_PATH=/), pas sous /n8n, sinon les cookies de session peuvent casser.
WEBHOOK_URL=https://automation.laroche360.ca/
N8N_EDITOR_BASE_URL=https://automation.laroche360.ca/
N8N_HOST=automation.laroche360.ca
N8N_PROTOCOL=https
N8N_PATH=/
N8N_PROXY_HOPS=1
N8N_SECURE_COOKIE=true
N8N_ONBOARDING_FLOW_DISABLED=true
N8N_PERSONALIZATION_ENABLED=false
N8N_DIAGNOSTICS_ENABLED=false
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# URL publique de votre webhook n8n en production
# Exemple: https://automation.laroche360.ca/webhook/rps-analysis
N8N_WEBHOOK_URL=https://automation.laroche360.ca/webhook/rps-analysis

# Google OAuth redirect URI a declarer dans Google Cloud
# https://automation.laroche360.ca/rest/oauth2-credential/callback

# Backend RPS appele par n8n pour callbacks et relances.
# Si n8n tourne dans le runtime Docker fourni par ce projet, utiliser le backend interne.
# Si n8n est externe au serveur Docker, utiliser l'URL publique https://appli.laroche360.ca/api.
BACKEND_API_URL=http://backend:3000/api
API_KEY=replace-me

# Email rapports et relances via SendGrid
SENDGRID_API_KEY=replace-me
SENDGRID_FROM_EMAIL=communications@laroche360.ca
SENDGRID_FROM_NAME=Laroche 360
SENDGRID_REPLY_TO=communications@laroche360.ca
REPORT_RECIPIENT_EMAIL=abondelire@gmail.com

# Google Drive
GOOGLE_DRIVE_FOLDER=replace-me
GOOGLE_DRIVE_SHARE_EMAIL=abondelire@gmail.com

# Relances automatiques
REMINDER_MIN_DAYS=6
REMINDER_MAX_COUNT=2

# Webhook production
# - Analyse RPS: N8N_WEBHOOK_URL doit finir par /webhook/rps-analysis
# - Relances: schedule n8n + GET BACKEND_API_URL/automation/campaigns/pending-reminders

# ============================================
# Notes pour le DevOps
# ============================================
# 1. n8n doit etre accessible en HTTPS via votre domaine unique
# 2. Le workflow "NEW WORKFLOW RSP.json" doit etre importe et active
# 3. Le webhook path dans n8n: "rps-analysis"
# 4. Le backend RPS doit etre accessible depuis n8n via BACKEND_API_URL
# 5. Il n'est pas necessaire d'exposer le port 5678 si le domaine/proxy HTTPS est deja configure
